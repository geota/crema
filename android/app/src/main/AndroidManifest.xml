<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Android 12+ (API 31+) BLE runtime permissions. -->
    <!-- BLUETOOTH_SCAN: discover the DE1. usesPermissionFlags="neverForLocation"
         declares the scan is not used to derive physical location, so the
         ACCESS_FINE_LOCATION grant is not also required on API 31+. -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />
    <!-- BLUETOOTH_CONNECT: connect to and exchange data with the DE1. -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_CONNECT"
        tools:targetApi="s" />

    <!-- Visualizer sync — OAuth token exchange + shot uploads to
         visualizer.coffee. The only network feature in the app. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Require BLE hardware. -->
    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="true" />

    <application
        android:allowBackup="false"
        android:icon="@android:drawable/ic_dialog_info"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Crema">

        <!-- singleTask: the Visualizer OAuth redirect re-enters the existing
             task via onNewIntent instead of stacking a second instance. -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Crema">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Visualizer OAuth callback: crema://visualizer/callback -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="crema" android:host="visualizer" />
            </intent-filter>
        </activity>
    </application>

</manifest>
