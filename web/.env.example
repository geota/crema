# Crema web shell — build-time environment variables.
#
# Vite exposes only variables prefixed `VITE_` to the client bundle.
# Copy this file to `.env.local` (gitignored) and fill the values for
# your environment.

# ─── Visualizer OAuth ──────────────────────────────────────────────────
#
# Doorkeeper Application "Client UID" — register a Public client
# (confidential = false) at https://visualizer.coffee/oauth/applications
# and paste the UID here.
#
# Different environments (local dev vs prod) should each have their own
# Doorkeeper application with its own redirect-URI whitelist:
#   dev:  http://localhost:5173/auth/visualizer/callback
#   prod: https://crema.coffee/auth/visualizer/callback   (or your host)
#
# Crema derives the redirect URI from `window.location.origin` at runtime
# — you only need to register the correct origin's callback URL in the
# Doorkeeper app, no env var to flip.
VITE_VISUALIZER_CLIENT_ID=

# ─── Google Drive backup (OAuth) ───────────────────────────────────────
#
# Google OAuth 2.0 *Web application* Client ID (PKCE — no client secret) for
# the optional Drive backup/restore feature. Create one at
# https://console.cloud.google.com/apis/credentials, authorise your origin's
# redirect URI (e.g. http://localhost:5173 for dev, or your prod host), and
# paste the Client ID here. Leave empty to disable Drive backup.
VITE_GOOGLE_DRIVE_CLIENT_ID=
