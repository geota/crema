node_modules/

# SvelteKit
.svelte-kit/

# adapter-static build output
build/

# wasm-pack output — generated by `pnpm wasm` from core/de1-wasm.
# Run `pnpm wasm` once before `pnpm dev`; `pnpm build` runs it automatically.
src/lib/wasm/

# Phosphor icon-font subset — generated by `pnpm icons` or a Vite buildStart
# hook (scripts/subset-phosphor.mjs). Regenerated automatically on dev/build.
src/lib/icons/

# PWA / Workbox generated assets
dev-dist/

# Local env (the user's per-environment Visualizer OAuth Client UID).
.env.local
.env.*.local

# mkcert-generated dev HTTPS certs. Visualizer's Doorkeeper rejects http://
# redirect URIs; running `pnpm dev` on https://localhost lets us register a
# dev OAuth Application with an HTTPS redirect URI. Generate with
# `mkcert localhost 127.0.0.1` inside web/.
*.pem

# OS / editor
.DS_Store
.vscode/
