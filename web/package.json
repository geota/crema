{
  "name": "crema-web",
  "private": true,
  "license": "GPL-3.0-or-later",
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "wasm": "wasm-pack build ../core/de1-wasm --target web --out-dir ../../web/src/lib/wasm --out-name de1_wasm",
    "dev": "vite dev",
    "build": "pnpm wasm && vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "test": "vitest run",
    "test:vitest": "vitest run",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "openapi": "openapi-typescript src/lib/visualizer/openapi.json -o src/lib/visualizer/openapi.d.ts"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.8.0",
    "@types/web-bluetooth": "^0.0.21",
    "@vite-pwa/sveltekit": "^1.1.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "subset-font": "^2.5.0",
    "svelte": "^5.55.7",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "bits-ui": "^2.18.1",
    "effect": "^3.21.2",
    "fflate": "^0.8.3",
    "phosphor-svelte": "^3.1.0",
    "uplot": "^1.6.32"
  }
}
